# ============================================================
# Evolution API Environment Configuration
# Copy this file to .env.evolution and update the values
# ============================================================

# ------ Server ------
SERVER_URL=http://localhost:8081
SERVER_PORT=8080

# ------ Authentication ------
# IMPORTANT: Change this to a strong, unique key for production!
AUTHENTICATION_API_KEY=your-evolution-api-key-change-me
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# ------ Database (PostgreSQL - shared with Flask app) ------
# Evolution stores instance metadata in its own tables
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:M.m03007493358@host.docker.internal:5432/isp_management
DATABASE_CONNECTION_CLIENT_NAME=evolution_api

# ------ Cache (Redis) ------
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/0
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false

# ------ Instance Settings ------
# Reject incoming calls (reduces noise for billing numbers)
CONFIG_SESSION_PHONE_CLIENT=Net Khata
CONFIG_SESSION_PHONE_NAME=Chrome

# ------ Webhook (optional - for receiving delivery receipts) ------
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# ------ Message Queueing ------
# Evolution's internal queue (we manage our own queue in Flask)
QRCODE_LIMIT=30
QRCODE_COLOR=#198754

# ------ Logging ------
LOG_LEVEL=WARN
LOG_COLOR=true
LOG_BAILEYS=error
