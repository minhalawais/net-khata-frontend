{
  "expo": {
    "name": "Net Khata",
    "slug": "net-khata-isp",
    "scheme": "net-khata-isp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "jsc",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.mbanet.ispapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "WRITE_SETTINGS",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "package": "com.mbanet.ispapp",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json"
    },
    "runtimeVersion": "1.0.0",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "build": {
        "babel": {
          "include": [
            "react-native-web"
          ]
        }
      },
      "bundler": "metro",
      "pwa": {
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "eas": {
        "projectId": "bcd8bce8-b52a-4a7c-9981-6ef75ce33e8c"
      }
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    }
  }
}